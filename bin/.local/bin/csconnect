#!/usr/bin/env bash

if [[ $# -eq 1 ]]; then
    selected=$1
else
    selected=$(gh cs list | fzf)
fi

if [[ -z $selected ]]; then
    exit 0;
fi

selected_name=$(echo $selected | awk '{print $1}')

if [[ "$TERM" == "xterm-ghostty" ]]; then
    infocmp -x xterm-ghostty | gh cs ssh -c "$selected_name" -- tic -x -
fi

# Forward all codespace ports locally in the background
ports=$(gh cs ports -c "$selected_name" --json sourcePort -q '.[].sourcePort')
if [[ -n "$ports" ]]; then
    port_pairs=""
    for port in $ports; do
        port_pairs="$port_pairs $port:$port"
    done
    gh cs ports forward $port_pairs -c "$selected_name" &
    ports_pid=$!
fi

cleanup() {
    [[ -n "$ports_pid" ]] && kill "$ports_pid" 2>/dev/null
    kill "$rdm_pid" 2>/dev/null
    rdm stop
}
trap cleanup EXIT

rdm server &
rdm_pid=$!
gh cs ssh -c "$selected_name" -- -t -R 127.0.0.1:7391:$(rdm socket)
